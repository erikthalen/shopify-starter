<section class="flex flex-col items-center gap-2 px-4 py-[5vh]">
  <h1 class="mb-4">Shopify Liquid starter</h1>

  <a
    class="-ml-6 flex items-center gap-2 text-neutral-500 hover:text-black"
    href="https://github.com/erikthalen/shopify-starter"
    aria-label="Link to GitHub repository"
  >
    <img src="{{ 'github.png' | asset_img_url }}" width="24" height="24" class="size-5" alt="">
    <span class="border-b border-dotted">GitHub</span>
  </a>
</section>

{% schema %}
{
  "name": "Welcome",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Delete me before you start"
    }
  ],
  "presets": [
    {
      "name": "Welcome"
    }
  ]
}
{% endschema %}
