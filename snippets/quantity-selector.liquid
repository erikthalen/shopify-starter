{% doc %}
  Outputs a number input with increment and decrement buttons.
  The value is stored in a hidden `<input>` and displayed in an `<output>` element.
  Managed by the `quantitySelector` [Alpine.js](https://alpinejs.dev/) component in `quantity-selector.ts`.

  @param {string} [name] - `name` attribute of the hidden input. Defaults to `quantity`.
  @param {number} [value] - Initial value. Defaults to `1`.
  @param {number} [min] - Minimum allowed value. Defaults to `0`.
  @param {string} [on-change] - Alpine.js expression called after the value changes (debounced).

  @example
  {% render 'quantity-selector', name: 'quantity', value: 1, min: 1 %}

  {% render 'quantity-selector',
    name: 'quantity',
    value: line_item.quantity,
    min: 0,
    on-change: 'submitForm()'
  %}
{% enddoc %}

<div
  id="quantity_selector"
  x-data="quantitySelector({ min: {{ min | default: 0 }}, init: {{ value | default: 1 }} })"
  class="flex items-center gap-3"
>
  <button
    type="button"
    @click="decrease"
    @click.debounce="{{ on-change | default: '' }}"
    class="ghost square"
    aria-label="Decrease quantity"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path vector-effect="non-scaling-stroke" d="M5 12l14 0" />
    </svg>
  </button>

  <input type="hidden" name="{{ name }}" value="{{ value | default: 1 }}">

  <span for="{{ name }}">{{ value | default: 1 }}</span>

  <small>
    <button
      type="button"
      @click="increase"
      @click.debounce="{{ on-change | default: '' }}"
      class="ghost square"
      aria-label="Increase quantity"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path vector-effect="non-scaling-stroke" d="M12 5l0 14" />
        <path vector-effect="non-scaling-stroke" d="M5 12l14 0" />
      </svg>
    </button>
  </small>
</div>
