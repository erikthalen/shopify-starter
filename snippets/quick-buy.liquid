{% doc %}
  Outputs a minimal add-to-cart button for the selected or first available variant.
  Quantity is fixed at 1. Shows "Sold out" and disables the button when the variant is unavailable.
  Includes a spinner icon that appears while the cart request is pending.

  @param {object} product - Shopify `product` object.

  @example
  {% render 'quick-buy', product: product %}
{% enddoc %}

{% assign variant = product.selected_or_first_available_variant %}

{% form 'product', product, x-target: 'cart cart_drawer_content cart_amount' %}
  <input type="hidden" name="quantity" value="1">
  <input type="hidden" name="id" value="{{ variant.id }}">

  <button
    class="quick-buy relative border-b border-dotted button flex items-center disabled:text-gray-300"
    type="submit"
    name="add"
    aria-label="Add {{ product.title }} - {{ variant.options | join: ' / ' }} to cart"
    {%- unless variant.available -%}
      disabled
    {%- endunless -%}
  >
    {%- if variant.available -%}
      Add to cart
    {%- else -%}
      Sold out
    {%- endif -%}

    <span class="size-3 absolute -right-6 opacity-0 transition-opacity">
      {% render 'icon-spinner' %}
    </span>
  </button>
{% endform %}

{% stylesheet %}
  .quick-buy[aria-disabled='true'] {
    span {
      opacity: 1;
    }
  }
{% endstylesheet %}
