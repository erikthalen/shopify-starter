{% doc %}
  Place this inside a paginated list container. When the snippet scrolls into view,
  the next page is fetched automatically and its items are appended to the list.
  The container must have `id="paginated_items"` and `x-merge="append"` for the swap to work.
  The intersection/fetch logic is handled by the `infiniteScroll` [Alpine.js](https://alpinejs.dev/) component in `infinite-scroll.ts`.

  @param {object} paginate - Shopify `paginate` object.

  @example
  {% paginate collection.products by 12 %}
    <ol id="paginated_items" x-merge="append">
      {% for product in collection.products %}
        <li>{{ product.title }}</li>
      {% endfor %}

      {% render 'infinite-scroll', paginate: paginate %}
    </ol>
  {% endpaginate %}
{% enddoc %}

{%- if paginate.next -%}
  <div x-data="infiniteScroll" class="contents">
    <div
      id="pagination"
      class="contents"
    >
      {% comment %} Loading skeletons {% endcomment %}
      {% for i in (1..3) %}
        {% if forloop.first %}
          <div
            x-intersect="$ajax('{{ paginate.next.url }}', { target: 'paginated_items pagination' })"
            @ajax:success="updateCache($event)"
          >
            {% render 'product-card-skeleton' %}
          </div>
        {% else %}
          {% render 'product-card-skeleton' %}
        {% endif %}
      {% endfor %}

      <a class="sr-only" href="{{ paginate.next.url }}"> Next page </a>
    </div>
  </div>
{%- endif -%}
