<!doctype html>
<html lang="{{ shop.locale }}">
  <head>
    <title>
      {{ page_title }}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    <link rel="icon" media="(prefers-color-scheme: light)" href="{{ settings.favicon_dark | image_url: width: 512, crop: false }}">
    <link rel="icon" media="(prefers-color-scheme: dark)" href="{{ settings.favicon_light | image_url: width: 512, crop: false }}">

    {% render 'meta-tags' %}

    {%- liquid
      render 'vite' with 'theme.css', preload_stylesheet: true
      render 'vite' with 'theme.ts'
    -%}

    {{ content_for_header }}
  </head>

  <body data-barba="wrapper">
    {% render 'site-header' %}

    <main data-barba="container" data-barba-namespace="main" role="main">
      {{ content_for_layout }}
    </main>
  </body>
</html>
